    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.15.8",
    "@rollup/plugin-babel": "^5.3.0",
    "@rollup/plugin-json": "^4.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^16.4.10",
    "babel-jest": "^29.7.0",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "eslint": "^7.32.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-plugin-import": "^2.23.4",
    "express": "^4.17.1",
    "husky": "4.2.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lerna": "^3.22.1",
    "lint-staged": "^11.1.1",
    "rollup": "^2.55.1"
  }
